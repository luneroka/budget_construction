// Docs: https://dbml.dbdiagram.io/docs

Project budget_construction {
  database_type: 'PostgreSQL'
}

Enum transaction_type {
  quote
  diy_estimate
  invoice
}

Enum quote_status {
  to_confirm
  to_negotiate
  validated
}

Enum invoice_status {
  unpaid
  on_hold
  paid
}

Enum payment_method {
  cash
  card
  wire
}

Enum project_item_type {
  product
  breakdown
}

Enum project_status {
  draft
  active
  completed
  archived
}

TablePartial timestamps {
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
}

Table users {
  id integer [pk, increment]
  name varchar(255) [not null]
  email varchar(255) [not null, unique]
  hashed_password varchar(255) [not null]
  ~timestamps
  is_admin boolean [not null, default: false]
  is_active boolean [not null, default: true]
  deleted_at timestamp
}

Table suppliers {
  id integer [pk, increment]
  user_id integer [not null]
  name varchar(255) [not null]
  email varchar(255)
  contact_name varchar(50)
  phone_number varchar(50)
  comment text
  ~timestamps
  deleted_at timestamp

  indexes {
    user_id [name: 'ix_suppliers_user_id']
    (user_id, name) [unique, name: 'uq_suppliers_user_id_name', note: 'Partial index: WHERE deleted_at IS NULL']
  }
}

Table projects {
  id integer [pk, increment]
  user_id integer [not null]
  name varchar(255) [not null]
  description text
  location varchar(255)
  start_date date
  end_date date
  project_status project_status [not null, default: 'active']
  ~timestamps
  deleted_at timestamp

  indexes {
    user_id [name: 'ix_projects_user_id']
    (user_id, name) [unique, name: 'uq_projects_user_id_name', note: 'Partial index: WHERE deleted_at IS NULL']
  }
}

Table categories {
  id integer [pk, increment]
  name varchar(255) [not null, unique]
  sort_order integer [not null, default: 0]
  is_active boolean [not null, default: true]
  ~timestamps
}

Table subcategories {
  id integer [pk, increment]
  category_id integer [not null]
  name varchar(255) [not null]
  sort_order integer [not null, default: 0]
  is_active boolean [not null, default: true]
  ~timestamps

  indexes {
    category_id [name: 'ix_subcategories_category_id']
    (category_id, name) [unique, name: 'uq_subcategories_category_id_name']
  }
}

Table products {
  id integer [pk, increment]
  subcategory_id integer [not null]
  name varchar(255) [not null]
  sort_order integer [not null, default: 0]
  is_active boolean [not null, default: true]
  ~timestamps

  indexes {
    subcategory_id [name: 'ix_products_subcategory_id']
    (subcategory_id, name) [unique, name: 'uq_products_subcategory_id_name']
  }
}

Table templates {
  id integer [pk, increment]
  name varchar(255) [not null, unique]
  description text
  is_active boolean [not null, default: true]
  ~timestamps
}

Table template_items {
  id integer [pk, increment]
  template_id integer [not null]
  product_id integer [not null]
  default_name varchar(255) [not null]
  sort_order integer [not null, default: 0]
  is_required boolean [not null, default: true]
  ~timestamps

  indexes {
    template_id [name: 'ix_template_items_template_id']
    product_id [name: 'ix_template_items_product_id']
  }
}

Table project_items {
  id integer [pk, increment]
  project_id integer [not null]
  template_item_id integer
  product_id integer [not null]
  name varchar(255) [not null]
  item_type project_item_type [not null]
  sort_order integer [not null, default: 0]
  ~timestamps
  deleted_at timestamp

  indexes {
    project_id [name: 'ix_project_items_project_id']
    template_item_id [name: 'ix_project_items_template_item_id']
    product_id [name: 'ix_project_items_product_id']
    (project_id, product_id) [unique, name: 'uq_project_items_project_id_product_id_product_type', note: 'Partial index: WHERE item_type = product AND deleted_at IS NULL']
  }

  Note: '''
    Products are the aggregation and reporting level.
    Breakdown project_items are linked directly to a product via product_id.
    project_items do not support parent/child relationships.
    For a given project + product, users must choose one budgeting mode:
    - one "product" project_item representing the whole product, or
    - multiple "breakdown" project_items representing sub-items.
    Mixing both modes for the same project + product is forbidden.
    Payment installments (acompte, solde, etc.) must be modeled as multiple
    transactions on the same project_item, not as additional breakdown project_items.
  '''
}

Table transactions {
  id integer [pk, increment]
  project_item_id integer [not null]
  supplier_id integer
  transaction_type transaction_type [not null]
  amount_ht decimal(12,2) [not null]
  vat_rate decimal(5,2)
  amount_vat decimal(12,2)
  amount_ttc decimal(12,2) [not null]
  transaction_date date [not null]
  description text
  quote_status quote_status
  invoice_status invoice_status
  payment_method payment_method
  is_selected_budget boolean [not null, default: false]
  ~timestamps
  deleted_at timestamp

  indexes {
    project_item_id [name: 'ix_transactions_project_item_id']
    supplier_id [name: 'ix_transactions_supplier_id']
    project_item_id [unique, name: 'uq_transactions_project_item_selected_budget', note: 'Partial index: WHERE is_selected_budget AND deleted_at IS NULL']
  }

  checks {
    `NOT is_selected_budget OR transaction_type IN ('quote', 'diy_estimate')` [name: 'ck_transactions_selected_budget_candidate']
    `amount_ht >= 0` [name: 'ck_transactions_amount_ht_positive']
    `vat_rate IS NULL OR vat_rate >= 0` [name: 'ck_transactions_vat_rate_positive']
    `amount_vat IS NULL OR amount_vat >= 0` [name: 'ck_transactions_amount_vat_positive']
    `amount_ttc >= 0` [name: 'ck_transactions_amount_ttc_positive']
    `amount_ttc >= amount_ht` [name: 'ck_transactions_ttc_greater_than_ht']
    `transaction_type = 'quote' OR quote_status IS NULL` [name: 'ck_transactions_quote_status_only_for_quotes']
    `transaction_type = 'invoice' OR invoice_status IS NULL` [name: 'ck_transactions_invoice_status_only_for_invoices']
    `transaction_type = 'invoice' OR payment_method IS NULL` [name: 'ck_transactions_payment_method_only_for_invoices']
  }
}

Table documents {
  id integer [pk, increment]
  transaction_id integer [not null]
  user_id integer [not null]
  original_filename varchar(255) [not null]
  stored_filename varchar(255) [not null]
  file_path varchar(255) [not null]
  mime_type varchar(255) [not null]
  file_size integer [not null]
  ~timestamps
  deleted_at timestamp

  indexes {
    id [name: 'ix_documents_id']
    transaction_id [name: 'ix_documents_transaction_id']
    user_id [name: 'ix_documents_user_id']
  }
}

Ref: suppliers.user_id > users.id [delete: cascade]
Ref: projects.user_id > users.id [delete: cascade]
Ref: subcategories.category_id > categories.id [delete: cascade]
Ref: products.subcategory_id > subcategories.id [delete: cascade]
Ref: template_items.template_id > templates.id [delete: cascade]
Ref: template_items.product_id > products.id
Ref: project_items.project_id > projects.id [delete: cascade]
Ref: project_items.template_item_id > template_items.id [delete: set null]
Ref: project_items.product_id > products.id
Ref: transactions.project_item_id > project_items.id [delete: cascade]
Ref: transactions.supplier_id > suppliers.id [delete: set null]
Ref: documents.transaction_id > transactions.id [delete: cascade]
Ref: documents.user_id > users.id [delete: cascade]
