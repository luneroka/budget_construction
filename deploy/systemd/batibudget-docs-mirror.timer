[Unit]
Description=Run the Bati Budget documents mirror daily

[Timer]
# Daily at 04:15 (server local time), offset from the 03:30 database backup
# so the two jobs don't contend for the VPS's limited bandwidth/CPU at once.
OnCalendar=*-*-* 04:15:00
# Run a missed mirror on next boot if the VPS was down at the scheduled time.
Persistent=true
# Avoid every scheduled job firing at the exact same second.
RandomizedDelaySec=300

[Install]
WantedBy=timers.target
