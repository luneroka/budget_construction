# PostgreSQL
POSTGRES_DB=dbname
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secret

# Backend
DATABASE_URL=postgresql+asyncpg://postgres:secret@db:5432/dbname
SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Resend settings
RESEND_API_KEY=
RESEND_FROM=onboarding@yourdomain.com
# Optional: public app URL used to build reset links
APP_URL=http://localhost:3000

# Frontend
VITE_API_URL=http://localhost:8000
