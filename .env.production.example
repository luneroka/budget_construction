# Public Caddy site. Both values are required for automatic HTTPS.
DOMAIN=app.example.com
ACME_EMAIL=ops@example.com

# PostgreSQL. Use a long, unique password. The database is internal to Docker.
POSTGRES_DB=budget_construction
POSTGRES_USER=budget_construction
POSTGRES_PASSWORD=replace-with-a-long-unique-password
DATABASE_URL=postgresql+asyncpg://budget_construction:replace-with-a-long-unique-password@db:5432/budget_construction

# Backend
APP_ENVIRONMENT=production
DATABASE_ECHO=false
SECRET_KEY=replace-with-a-random-64-character-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Sliding refresh-token session length; the httpOnly refresh cookie's expiry
# extends by this many days on every use while the user stays active.
REFRESH_TOKEN_EXPIRE_DAYS=30
APP_URL=https://app.example.com
CORS_ALLOWED_ORIGINS=["https://app.example.com"]

# Cloudflare R2 (use a bucket-scoped, least-privilege API token)
R2_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=replace-me
R2_SECRET_ACCESS_KEY=replace-me
R2_BUCKET_NAME=budget-construction-production

# Resend (verify the sender domain before deployment)
RESEND_API_KEY=re_replace_me
RESEND_FROM=Budget Construction <no-reply@example.com>
SUPPORT_EMAIL=support@example.com

# Frontend build-time setting; browser requests are proxied by Caddy.
VITE_API_BASE_URL=/api

# Sentry (optional but recommended in production): captures unhandled
# backend exceptions with full context and alerts you, independent of the
# VPS's own log retention (which is discarded on every deploy). Use a
# project DEDICATED to this app, not shared with another project. Leaving
# this unset is a safe no-op -- the app runs normally, it just isn't
# reported anywhere if something unexpected breaks.
SENTRY_DSN=

# --- Database backups (scripts/backup_db.sh) ---
# Passphrase used to AES-256 encrypt each backup. KEEP A COPY OFF THE VPS
# (e.g. in a password manager): without it, every backup is unrecoverable.
BACKUP_ENCRYPTION_PASSPHRASE=replace-with-a-long-random-passphrase
# Off-host destination: a DEDICATED Cloudflare R2 bucket with its own
# least-privilege API token (separate from the documents bucket above).
# Leave BACKUP_R2_BUCKET empty to keep backups local-only (not recommended).
BACKUP_R2_BUCKET=budget-construction-backups
BACKUP_R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
BACKUP_R2_ACCESS_KEY_ID=replace-me
BACKUP_R2_SECRET_ACCESS_KEY=replace-me
# Retention (days): local copies on the VPS, and objects kept in R2.
BACKUP_LOCAL_RETENTION_DAYS=7
BACKUP_REMOTE_RETENTION_DAYS=30
# Optional: where to send an alert email if a backup run fails. Reuses the
# RESEND_API_KEY/RESEND_FROM above (no separate Resend config needed).
# Defaults to SUPPORT_EMAIL if left unset.
BACKUP_ALERT_EMAIL=support@example.com

# --- Documents mirror (scripts/backup_documents.sh) ---
# R2 has no object/bucket versioning, so this is the substitute: a daily
# one-way copy (never a delete-propagating sync) of the live documents
# bucket (R2_BUCKET_NAME above) into a SEPARATE mirror bucket. A deleted
# document is still recoverable from the mirror even after the live copy is
# gone. Retention on the mirror bucket is enforced by an R2 Object Lifecycle
# Rule configured directly on that bucket in the Cloudflare dashboard (not
# by this script) -- see the Disaster Recovery section of the runbook.
# Use a DEDICATED API token scoped to Object Read & Write on ONLY the live
# documents bucket and this mirror bucket (not the DB backups bucket above).
DOCS_BACKUP_R2_BUCKET=budget-construction-documents-backup
# Defaults to R2_ENDPOINT_URL if left unset (same Cloudflare account).
DOCS_BACKUP_R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
DOCS_BACKUP_R2_ACCESS_KEY_ID=replace-me
DOCS_BACKUP_R2_SECRET_ACCESS_KEY=replace-me
